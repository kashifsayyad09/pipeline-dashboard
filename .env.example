# GitHub Actions Analytics Dashboard — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# GitHub Personal Access Token (classic) or Fine-Grained PAT
# Required scopes: repo, workflow, read:org, read:user
GITHUB_TOKEN=ghp_your_token_here

# ── Optional: GitHub Enterprise ───────────────────────────────────────────────
# Leave blank to use public GitHub (api.github.com)
GITHUB_API_URL=https://api.github.com
